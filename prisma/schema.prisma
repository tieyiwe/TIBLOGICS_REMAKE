generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Appointment {
  id              String    @id @default(cuid())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  serviceType     String
  serviceDuration String
  servicePrice    Int
  date            DateTime
  timeSlot        String
  timezone        String    @default("America/New_York")
  firstName       String
  lastName        String
  email           String
  company         String?
  goalNotes       String?
  addOnRecording      Boolean @default(false)
  addOnActionPlan     Boolean @default(false)
  addOnSlackAccess    Boolean @default(false)
  totalAmount     Int
  status          AppointmentStatus @default(PENDING)
  stripeSessionId  String?
  stripePaymentId  String?
  paymentStatus    String?
  zoomLink         String?
  notes            String?
  reminderSent     Boolean   @default(false)
  confirmedAt      DateTime?
  cancelledAt      DateTime?
  cancelReason     String?

  @@index([email])
  @@index([date])
  @@index([status])
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

model Prospect {
  id                 String         @id @default(cuid())
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  name               String
  business           String
  industry           String
  mainChallenge      String
  budget             String
  suggestedSolutions String[]
  email              String?
  phone              String?
  source             ProspectSource @default(TIBS_ADVISOR)
  status             ProspectStatus @default(NEW)
  priority           String?
  estimatedValue     Int?
  notes              String?
  followUpDate       DateTime?
  convertedAt        DateTime?
  conversationLog    Json?
  archived           Boolean        @default(false)

  @@index([status])
  @@index([createdAt])
  @@index([archived])
}

enum ProspectSource {
  TIBS_ADVISOR
  WEBSITE_SCANNER
  CONTACT_FORM
  REFERRAL
  MANUAL
}

enum ProspectStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  NEGOTIATING
  CLOSED_WON
  CLOSED_LOST
  ON_HOLD
}

model ScannerLead {
  id            String    @id @default(cuid())
  createdAt     DateTime  @default(now())
  url           String
  overallScore  Int
  seoScore      Int
  perfScore     Int
  uxScore       Int
  aiScore       Int
  findings      Json
  aiDescription String
  email         String?
  name          String?
  bookedCallAt  DateTime?

  @@index([createdAt])
  @@index([aiScore])
}

model ToolUsage {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  tool      String
  sessionId String?
  metadata  Json?
}

model AdminSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model BlockedDate {
  id        String   @id @default(cuid())
  date      DateTime
  reason    String?
  createdAt DateTime @default(now())
}

model Project {
  id               String          @id @default(cuid())
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  name             String
  description      String?
  category         ProjectCategory
  status           ProjectStatus   @default(ACTIVE)
  priority         ProjectPriority @default(MEDIUM)
  progress         Int             @default(0)
  color            String          @default("#2251A3")
  revenueEarned    Int             @default(0)
  revenuePotential Int             @default(0)
  monthlyRecurring Int             @default(0)
  startDate        DateTime?
  deadline         DateTime?
  completedAt      DateTime?
  starred          Boolean         @default(false)
  archived         Boolean         @default(false)
  notes            String?
  tasks            ProjectTask[]

  @@index([category])
  @@index([status])
}

enum ProjectCategory {
  SAAS
  CLIENT
  EDUCATION
  INTERNAL
}

enum ProjectStatus {
  CONCEPT
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum ProjectPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model ProjectTask {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  text      String
  done      Boolean  @default(false)
  createdAt DateTime @default(now())
  dueDate   DateTime?
  order     Int      @default(0)

  @@index([projectId])
}

model NewsletterSubscriber {
  id             String    @id @default(cuid())
  email          String    @unique
  firstName      String?
  source         String    @default("blog")
  active         Boolean   @default(true)
  subscribedAt   DateTime  @default(now())
  unsubscribedAt DateTime?

  @@index([active])
  @@index([subscribedAt])
}

model NewsletterCampaign {
  id             String    @id @default(cuid())
  title          String
  subject        String
  previewText    String?
  contentHtml    String    @db.Text
  category       String    @default("general")
  status         String    @default("DRAFT")
  sentAt         DateTime?
  recipientCount Int       @default(0)
  sentBy         String    @default("Echelon")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model ServiceRequest {
  id           String   @id @default(cuid())
  firstName    String
  lastName     String
  email        String
  phone        String?
  company      String?
  service      String
  description  String   @db.Text
  budget       String?
  timeline     String?
  tiboAssisted Boolean  @default(false)
  aiSummary    String?  @db.Text
  status       String   @default("NEW")
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

model BlogPost {
  id            String   @id @default(cuid())
  slug          String   @unique
  title         String
  excerpt       String   @db.Text
  content       String   @db.Text
  category      String
  tags          String[]
  coverImage    String?
  coverEmoji    String   @default("🤖")
  coverGradient String   @default("from-[#1B3A6B] to-[#2251A3]")
  author        String   @default("Echelon AI")
  readingTime   Int      @default(5)
  featured      Boolean  @default(false)
  published     Boolean  @default(true)
  aiGenerated   Boolean  @default(false)
  sourceUrl     String?
  sourceTitle   String?
  viewCount     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([category])
  @@index([published])
  @@index([featured])
  @@index([createdAt])
}

model BreakingNews {
  id        String    @id @default(cuid())
  headline  String
  summary   String
  sourceUrl String?
  source    String?
  active    Boolean   @default(true)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
}

model BlogRefreshLog {
  id         String   @id @default(cuid())
  success    Boolean
  postsAdded Int      @default(0)
  message    String?
  createdAt  DateTime @default(now())
}

model CommandCenterSync {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now())
  projectId   String?
  projectName String
  action      String
  source      String
  changesDiff Json
  chatSummary String?
  undoneAt    DateTime?
}

model PageView {
  id        String   @id @default(cuid())
  page      String
  referrer  String?
  origin    String   @default("direct")
  device    String   @default("desktop")
  browser   String?
  os        String?
  ip        String?
  sessionId String
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([sessionId])
  @@index([origin])
}

model ActiveSession {
  id        String   @id @default(cuid())
  sessionId String   @unique
  page      String
  device    String   @default("desktop")
  browser   String?
  os        String?
  origin    String   @default("direct")
  ip        String?
  lastSeen  DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([lastSeen])
}

model Collaborator {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  passwordHash  String?
  role          String    @default("CUSTOM")
  permissions   String[]
  isAdmin       Boolean   @default(false)
  active        Boolean   @default(true)
  inviteToken   String?   @unique
  inviteExpires DateTime?
  invitedBy     String
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  activityLogs  CollaboratorActivityLog[]

  @@index([email])
  @@index([inviteToken])
}

model CollaboratorActivityLog {
  id             String       @id @default(cuid())
  collaboratorId String
  collaborator   Collaborator @relation(fields: [collaboratorId], references: [id], onDelete: Cascade)
  action         String
  resource       String
  resourceId     String?
  details        String?
  ip             String?
  createdAt      DateTime     @default(now())

  @@index([collaboratorId])
  @@index([createdAt])
  @@index([resource])
}

model AgentLead {
  id            String          @id @default(cuid())
  source        String          @default("ai_generated")
  companyName   String
  contactName   String?
  email         String?
  phone         String?
  website       String?
  location      String?
  industry      String?
  description   String?         @db.Text
  notes         String?         @db.Text
  status        AgentLeadStatus @default(NEW)
  fromAgent     String          @default("aria")
  assignedTo    String?
  callSid       String?
  callStatus    String?
  callNotes     String?         @db.Text
  transferredAt DateTime?
  contactedAt   DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([status])
  @@index([fromAgent])
  @@index([assignedTo])
}

enum AgentLeadStatus {
  NEW
  TRANSFERRED
  CONTACTED
  HOT
  WARM
  COLD
  UNINTERESTED
  CONVERTED
}

model AgentMessage {
  id        String   @id @default(cuid())
  fromAgent String
  toAgent   String
  type      String   @default("notification")
  subject   String?
  payload   Json     @default("{}")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([toAgent, read])
  @@index([fromAgent])
}

model AgentRun {
  id        String   @id @default(cuid())
  agent     String
  action    String
  status    String   @default("running")
  input     Json?
  output    Json?
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agent])
  @@index([status])
}

model PartnershipApplication {
  id           String   @id @default(cuid())
  businessName String
  contactName  String
  email        String
  phone        String
  website      String?
  address      String?
  description  String
  createdAt    DateTime @default(now())

  @@index([createdAt])
}

model WaitlistEntry {
  id        String   @id @default(cuid())
  email     String
  product   String
  createdAt DateTime @default(now())

  @@unique([email, product])
  @@index([product])
  @@index([createdAt])
}
