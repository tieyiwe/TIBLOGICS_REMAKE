modules = ["nodejs-20"]

[nix]
channel = "stable-24_05"

hidden = [".build", ".config", "node_modules", ".next"]

[workflows]
runButton = "Dev"

[[workflows.workflow]]
name = "Dev"
author = "agent"
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 3000

[[workflows.workflow]]
name = "Build & Start"
author = "agent"
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run build"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run start"
waitForPort = 3000

[deployment]
build = ["sh", "-c", "npm run build"]
run = ["sh", "-c", "npm run start"]

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 3001
externalPort = 3001

[agent]
expertMode = true
