modules = ["nodejs-20"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start"

[[workflows.workflow]]
name = "Start"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "fuser -k 3000/tcp 2>/dev/null || true; npm run build && npm run start"
waitForPort = 3000

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 3000
externalPort = 3000

[deployment]
deploymentTarget = "autoscale"
run = ["sh", "-c", "npm run start"]
build = ["sh", "-c", "npm run build"]
