modules = ["nodejs-20"]

[nix]
channel = "stable-24_05"

hidden = [".build", ".config", "node_modules", ".next"]

[workflows]
runButton = "Start"

[[workflows.workflow]]
name = "Start"
author = "agent"
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "fuser -k 3000/tcp 2>/dev/null || true; npm run build && npm run start"
waitForPort = 3000

[deployment]
build = ["sh", "-c", "npm run build"]
run = ["sh", "-c", "npm run start"]

[[ports]]
localPort = 3000
externalPort = 80

[agent]
expertMode = true
