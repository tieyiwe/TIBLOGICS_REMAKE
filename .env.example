# ============================================================
# TIBLOGICS ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in your values
# ============================================================

# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# NextAuth
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# Admin credentials (single admin account for TIWE)
ADMIN_EMAIL="ai@tiblogics.com"
ADMIN_PASSWORD="your-strong-password-here"
ADMIN_NAME="Tieyiwe Bassole"

# Anthropic (Claude AI)
ANTHROPIC_API_KEY="sk-ant-api03-..."

# Stripe
STRIPE_SECRET_KEY="sk_test_..."         # Use sk_live_ for production
STRIPE_WEBHOOK_SECRET="whsec_..."

# These are public (exposed to browser via NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."   # Use pk_live_ for production
NEXT_PUBLIC_APP_URL="http://localhost:3000"         # Use https://tiblogics.com in production

# Resend (transactional email)
RESEND_API_KEY="re_..."
FROM_EMAIL="noreply@tiblogics.com"
TIWE_EMAIL="ai@tiblogics.com"

# ============================================================
# SETUP INSTRUCTIONS
# ============================================================
#
# 1. DATABASE:
#    - Create a Supabase project at supabase.com
#    - Copy the connection string from Settings > Database
#    - Run: npx prisma db push
#    - Run: npm run db:seed  (loads 15 Command Center projects)
#
# 2. NEXTAUTH:
#    - Generate secret: openssl rand -base64 32
#    - Set NEXTAUTH_URL to your domain in production
#
# 3. STRIPE:
#    - Create account at stripe.com
#    - Get keys from Developers > API keys
#    - Set up webhook at Developers > Webhooks
#    - Webhook URL: https://yourdomain.com/api/stripe/webhook
#    - Events to listen for: checkout.session.completed
#
# 4. RESEND:
#    - Create account at resend.com
#    - Add and verify your sending domain
#    - Get API key from Settings > API Keys
#
# 5. ANTHROPIC:
#    - Get API key from console.anthropic.com
#    - Model used: claude-sonnet-4-20250514
#
# 6. COMMAND CENTER WEBHOOK TOKEN:
#    - Generate in Admin > Settings > Command Center Sync
#    - Used to authenticate POST /api/admin/cc-webhook
#    - Store as CC_WEBHOOK_TOKEN in your Claude Code env
